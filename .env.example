# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: deep link / web URL Supabase redirects to after “reset password” email (must be allowlisted in Supabase Auth redirect URLs).
EXPO_PUBLIC_AUTH_PASSWORD_RESET_REDIRECT_URL=

# Server-only: seed/migration scripts (e.g. npm run seed:premium-baby-names). Never use in the Expo client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PostHog (project API key — safe for client; never use a personal/private API key here)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# RevenueCat
EXPO_PUBLIC_REVENUECAT_TEST_STORE_API_KEY=test_your-test-store-key-here
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-ios-public-key-here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-android-public-key-here
