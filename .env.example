# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only: seed/migration scripts (e.g. npm run seed:premium-baby-names). Never use in the Expo client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# RevenueCat
EXPO_PUBLIC_REVENUECAT_TEST_STORE_API_KEY=test_your-test-store-key-here
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-ios-public-key-here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-android-public-key-here
